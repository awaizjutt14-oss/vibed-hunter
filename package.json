{
  "name": "content-hunter-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=true next dev",
    "build": "SCHEMA=prisma/schema.prisma; if [ \"$DEV_NO_DOCKER\" = \"true\" ] || echo \"${DATABASE_URL:-}\" | grep -q '^file:'; then SCHEMA=prisma/schema.dev.prisma; fi; prisma generate --schema $SCHEMA && PRISMA_SCHEMA_PATH=$SCHEMA next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node --experimental-strip-types prisma/seed.ts",
    "prisma:generate:dev": "prisma generate --schema prisma/schema.dev.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.dev.prisma",
    "prisma:push:dev": "prisma db push --schema prisma/schema.dev.prisma",
    "prisma:seed:dev": "node --experimental-strip-types prisma/seed.ts",
    "jobs:worker": "tsx scripts/run-worker.ts",
    "jobs:scheduler": "tsx scripts/run-scheduler.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@tanstack/react-query": "^5.69.0",
    "bullmq": "^5.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.6.1",
    "lucide-react": "^0.511.0",
    "next": "^15.2.2",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.4",
    "openai": "^4.92.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.55.0",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
